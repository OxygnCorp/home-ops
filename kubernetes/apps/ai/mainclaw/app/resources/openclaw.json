  "bindings": [
    {
      "agentId": "main",
      "match": {
        "channel": "discord",
        "peer": {
          "kind": "channel",
          "id": "{{ .DISCORD_CLAW_CHANNEL_ID }}"
        },
        "guildId": "{{ .DISCORD_GUILD_ID }}"
      }
    },
    {
      "agentId": "family",
      "match": {

{
  "id": null,
  "title": "LiteLLM Economics",
  "tags": ["llm", "litellm", "cost"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": [],
      "title": "This month so far — your situation",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Opencode Go + MiniMax Starter (tunable variables).",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "vector(($sub_opencode + $sub_minimax))",
          "refId": "A"
        }
      ],
      "title": "Flat subs / mo",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "What this month's tokens would cost metered, each bucket at its own provider rate.",
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 }, "overrides": [] },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(((sum(increase(litellm_input_tokens_metric_total{requested_model=~\"opencode.*\"}[$__range])) or vector(0)) * 0.4 + (sum(increase(litellm_output_tokens_metric_total{requested_model=~\"opencode.*\"}[$__range])) or vector(0)) * 1.5) / 1e6) + (((sum(increase(litellm_input_tokens_metric_total{requested_model=~\"MiniMax.*\"}[$__range])) or vector(0)) * 0.3 + (sum(increase(litellm_output_tokens_metric_total{requested_model=~\"MiniMax.*\"}[$__range])) or vector(0)) * 1.2) / 1e6)",
          "refId": "A"
        }
      ],
      "title": "MTD API-equiv (own rates)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Every token this month priced as if it ran on Claude Opus 4.8 (5/25).",
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 }, "overrides": [] },
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "((sum(increase(litellm_input_tokens_metric_total[$__range])) or vector(0)) * 5.0 + (sum(increase(litellm_output_tokens_metric_total[$__range])) or vector(0)) * 25.0) / 1e6",
          "refId": "A"
        }
      ],
      "title": "MTD API-equiv (all-Opus)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "MTD own-rate cost extrapolated to a full month at the current burn rate.",
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 }, "overrides": [] },
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "((((sum(increase(litellm_input_tokens_metric_total{requested_model=~\"opencode.*\"}[$__range])) or vector(0)) * 0.4 + (sum(increase(litellm_output_tokens_metric_total{requested_model=~\"opencode.*\"}[$__range])) or vector(0)) * 1.5) / 1e6 + (((sum(increase(litellm_input_tokens_metric_total{requested_model=~\"MiniMax.*\"}[$__range])) or vector(0)) * 0.3 + (sum(increase(litellm_output_tokens_metric_total{requested_model=~\"MiniMax.*\"}[$__range])) or vector(0)) * 1.2) / 1e6) * (${days_in_month} * 86400 / $__range_s)",
          "refId": "A"
        }
      ],
      "title": "Projected month (own rates)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Projected own-rate API cost minus your flat subscription spend. Green = subscriptions win.",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0 }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 1 },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "((((sum(increase(litellm_input_tokens_metric_total{requested_model=~\"opencode.*\"}[$__range])) or vector(0)) * 0.4 + (sum(increase(litellm_output_tokens_metric_total{requested_model=~\"opencode.*\"}[$__range])) or vector(0)) * 1.5) / 1e6 + (((sum(increase(litellm_input_tokens_metric_total{requested_model=~\"MiniMax.*\"}[$__range])) or vector(0)) * 0.3 + (sum(increase(litellm_output_tokens_metric_total{requested_model=~\"MiniMax.*\"}[$__range])) or vector(0)) * 1.2) / 1e6) * (${days_in_month} * 86400 / $__range_s) - ($sub_opencode + $sub_minimax)",
          "refId": "A"
        }
      ],
      "title": "You save vs API / mo",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Projected all-Opus API cost minus your flat subscription spend.",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0 }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 1 },
      "id": 7,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(((sum(increase(litellm_input_tokens_metric_total[$__range])) or vector(0)) * 5.0 + (sum(increase(litellm_output_tokens_metric_total[$__range])) or vector(0)) * 25.0) / 1e6) * (${days_in_month} * 86400 / $__range_s) - ($sub_opencode + $sub_minimax)",
          "refId": "A"
        }
      ],
      "title": "You save vs all-Opus / mo",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 8,
      "panels": [],
      "title": "Subscription vs API — projected monthly savings per bucket",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Projected full-month API-equivalent cost of each bucket's tokens minus its flat fee.",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 9,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "valueMode": "color",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "label_replace((((sum(increase(litellm_input_tokens_metric_total{requested_model=~\"opencode.*\"}[$__range])) or vector(0)) * 0.4 + (sum(increase(litellm_output_tokens_metric_total{requested_model=~\"opencode.*\"}[$__range])) or vector(0)) * 1.5) / 1e6) * (${days_in_month} * 86400 / $__range_s) - ($sub_opencode), \"bucket\", \"Opencode Go\", \"\", \"\")",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "label_replace((((sum(increase(litellm_input_tokens_metric_total{requested_model=~\"MiniMax.*\"}[$__range])) or vector(0)) * 0.3 + (sum(increase(litellm_output_tokens_metric_total{requested_model=~\"MiniMax.*\"}[$__range])) or vector(0)) * 1.2) / 1e6) * (${days_in_month} * 86400 / $__range_s) - ($sub_minimax), \"bucket\", \"MiniMax\", \"\", \"\")",
          "refId": "B"
        }
      ],
      "title": "Projected savings by bucket (API-equiv − flat)",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "API-equivalent spend rate per bucket, expressed as $/day.",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "custom": { "drawStyle": "line", "fillOpacity": 30, "stacking": { "mode": "normal" }, "lineWidth": 1 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "id": 10,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "((sum(rate(litellm_input_tokens_metric_total{requested_model=~\"opencode.*\"}[$__rate_interval])) * 0.4 + sum(rate(litellm_output_tokens_metric_total{requested_model=~\"opencode.*\"}[$__rate_interval])) * 1.5) / 1e6) * 86400",
          "refId": "A",
          "legendFormat": "Opencode Go"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "((sum(rate(litellm_input_tokens_metric_total{requested_model=~\"MiniMax.*\"}[$__rate_interval])) * 0.3 + sum(rate(litellm_output_tokens_metric_total{requested_model=~\"MiniMax.*\"}[$__rate_interval])) * 1.2) / 1e6) * 86400",
          "refId": "B",
          "legendFormat": "MiniMax"
        }
      ],
      "title": "API-equivalent $/day by bucket",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 13,
      "panels": [],
      "title": "Where your tokens actually go",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Share of this month's tokens by routing bucket.",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "id": 14,
      "options": {
        "displayLabels": ["name", "percent"],
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "label_replace((sum(increase(litellm_total_tokens_metric_total{requested_model=~\"opencode.*\"}[$__range])) or vector(0)), \"bucket\", \"Opencode\", \"\", \"\")",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "label_replace((sum(increase(litellm_total_tokens_metric_total{requested_model=~\"MiniMax.*\"}[$__range])) or vector(0)), \"bucket\", \"MiniMax\", \"\", \"\")",
          "refId": "B"
        }
      ],
      "title": "Tokens by bucket (MTD)",
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Per-model breakdown of this month's traffic.",
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "align": "auto" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 16 },
      "id": 15,
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Total tokens", "desc": true }]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (requested_model) (increase(litellm_total_tokens_metric_total[$__range]))",
          "refId": "A",
          "instant": true,
          "format": "table",
          "range": false
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (requested_model) (increase(litellm_input_tokens_metric_total[$__range]))",
          "refId": "B",
          "instant": true,
          "format": "table",
          "range": false
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (requested_model) (increase(litellm_output_tokens_metric_total[$__range]))",
          "refId": "C",
          "instant": true,
          "format": "table",
          "range": false
        }
      ],
      "title": "Per-model usage (MTD)",
      "type": "table",
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": { "requested_model": 0, "Value #A": 1, "Value #B": 2, "Value #C": 3 },
            "renameByName": { "requested_model": "Model", "Value #A": "Total tokens", "Value #B": "Input", "Value #C": "Output" }
          }
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "current": { "text": "Prometheus", "value": "prometheus" },
        "hide": 2,
        "label": "Datasource",
        "name": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "name": "sub_opencode",
        "label": "Opencode Go $/mo (USD)",
        "type": "textbox",
        "current": { "text": "10", "value": "10" },
        "query": "10"
      },
      {
        "name": "sub_minimax",
        "label": "MiniMax $/mo (USD)",
        "type": "textbox",
        "current": { "text": "20", "value": "20" },
        "query": "20"
      },
      {
        "name": "days_in_month",
        "label": "Days in month",
        "type": "textbox",
        "current": { "text": "30", "value": "30" },
        "query": "30"
      }
    ]
  },
  "time": { "from": "now/M", "to": "now" },
  "timepicker": {}
}